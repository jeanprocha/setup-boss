OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

ARCHITECT_MODEL=gpt-5.4-mini
EXECUTOR_MODEL=gpt-5.4-mini
REVIEW_MODEL=gpt-5.4-mini
CORRECTION_MODEL=gpt-5.4-mini
KNOWLEDGE_MODEL=gpt-5.4-mini
SCAN_MODEL=gpt-5.4-mini
ENSURE_IA_MODEL=gpt-5.4-mini
SEMANTIC_IA_MODEL=gpt-5.4-mini

GPT_5_4_INPUT_USD_PER_1M=
GPT_5_4_OUTPUT_USD_PER_1M=
GPT_5_4_MINI_INPUT_USD_PER_1M=
GPT_5_4_MINI_OUTPUT_USD_PER_1M=

MAX_CORRECTIONS=3
MAX_TOTAL_STEPS=20

# Recovery (fase 2.6) — orçamentos de retry supervisionado
SETUP_BOSS_EXECUTOR_MICRO_RETRY_MAX=2
SETUP_BOSS_PROVIDER_RETRY_MAX=3
SETUP_BOSS_CORRECTION_RETRY_BUDGET=1

ENABLE_SCAN_CACHE=true

FORCE_SCAN=
# Se definido (ex.: 1 ou true), força scan na corrida ignorando cache do run.js (alternativa a passar --force-scan ao node scripts/run.js).

SCAN_FILE_TREE_MAX_CHARS=12000
# Teto de caracteres da árvore de ficheiros no prompt do scan; <= 0 desativa truncagem.

SCAN_OPERATIONAL_DOCS_MAX_CHARS=12000
# Teto de caracteres dos docs operacionais (setup-boss/docs) no prompt do scan; <= 0 desativa.

SCAN_GLOBAL_CONTEXT_MAX_CHARS=6000
# Teto de caracteres do contexto global (setup-boss/context) no prompt do scan; <= 0 desativa.

ARCHITECT_PROJECT_SCAN_MAX_CHARS=8000
# Teto do texto PROJECT SCAN (project-scan.md) no prompt do architect; <= 0 sem truncagem.

EXECUTOR_CONTEXT_SNIPPET_SIZE=6000
# Tamanho máximo do snippet por arquivo permitido no executor (caracteres por ficheiro).
# Aumentar para tasks em ficheiros grandes (ex.: componentes React extensos).
# Exemplo: 24000 para componentes muito grandes (~19k chars ou mais).
# <= 0 não deve ser usado, salvo se o código suportar explicitamente esse valor.

# --- Governança / política runtime (Fase 2.7) ---
SETUP_BOSS_POLICY_PROFILE=
# Perfis FAST, NORMAL, STRICT, ENTERPRISE (ou NONE / OFF para desactivar só via env onde suportado).
SETUP_BOSS_FORCE_POLICY_BYPASS=
# Defina como 1/true/yes apenas para auditoria deliberada (--force-policy-bypass na CLI).
SETUP_BOSS_DISABLE_GOVERNANCE=
# 1/true/yes desliga o motor de governança nesta sessão/processo.

# Runtime API local (Fase 3.2) — apenas 127.0.0.1; default 3210
SETUP_BOSS_RUNTIME_API_PORT=3210
# Timeout por pedido HTTP ao servidor da API (ms). Default 30000.
SETUP_BOSS_RUNTIME_API_REQUEST_TIMEOUT_MS=30000

# Estado do daemon/fila/events fora de `<repo>/.setup-boss` (opcional; útil para testes isolados ou várias instâncias)
SETUP_BOSS_DATA_DIR=

# Worker pool local (Fase 3.8) — paralelismo entre projectos; default 1 (= comportamento legacy)
SETUP_BOSS_MAX_WORKERS=1
# Limite de workers ocupando o mesmo projectId em simultâneo (default 1); lock por projeto continua obrigatório
SETUP_BOSS_MAX_WORKERS_PER_PROJECT=1

# Scheduler (jobs delayed / disponibilidade)
SETUP_BOSS_SCHEDULER_POLL_MS=1500

# Testes E2E internos — quando "1", scripts/run.js termina sem pipeline (só para integração CI/daemon)
SETUP_BOSS_E2E_WORKER_NOOP=
SETUP_BOSS_E2E_WORKER_SLEEP_MS=
SETUP_BOSS_E2E_WORKER_EXIT_CODE=

SETUP_BOSS_POLICY_MAX_COST_USD=
# Opcional — teto de custo USD estimado (preços por modelo já definidos por cima).

SETUP_BOSS_POLICY_MAX_FILES=
# Opcional — teto máximo sobre a estimativa de ficheiros (inteiro positivo).

# Execution Plan (Fase 4.1) — modo shadow do IR operacional
SETUP_BOSS_PLAN_MODE=off
# off → sem geração de plano | shadow → gera execution-plan.json (não altera executor PATCH)

# Execution Graph (Fase 4.12.1) — modelo estrutural derivado por run
SETUP_BOSS_EXECUTION_GRAPH=off
# off (default) → sem artefacto | shadow → grava <projeto>/.IA/outputs/<runId>/execution-graph.json (não altera orquestração)

# Execution Graph Runtime (Fase 4.12.2) — estado transitório por nó (observabilidade)
SETUP_BOSS_EXECUTION_GRAPH_RUNTIME=off
# off (default) → sem artefacto | shadow → grava execution-graph-runtime.json no mesmo outputDir

# Execution Graph Scheduler (Fase 4.12.3) — simulação serial advisory, relatório derivado
SETUP_BOSS_EXECUTION_GRAPH_SCHEDULER=off
# off (default) | shadow → grava execution-graph-scheduler-report.json (sem alterar pipeline)

# Execution Graph Overlay (Fase 4.12.4) — comparação linear vs DAG (observabilidade)
SETUP_BOSS_EXECUTION_GRAPH_OVERLAY=off
# off (default) | shadow → grava execution-graph-overlay-report.json (sem alterar pipeline)

# Execution Graph Node Adapters (Fase 4.12.5) — metadados/contratos por nó (shadow)
SETUP_BOSS_EXECUTION_GRAPH_NODE_ADAPTERS=off
# off (default) | shadow → grava execution-graph-node-adapters.json (sem executar runtimes de etapa)

# Execution Graph Replay (Fase 4.12.6) — planeamento advisory / invalidação (shadow)
SETUP_BOSS_EXECUTION_GRAPH_REPLAY=off
# off (default) | shadow → grava execution-graph-replay-report.json (sem executar pipeline nem handlers)
# Opcional: SETUP_BOSS_EXECUTION_GRAPH_REPLAY_TARGETS=n-executor (lista separada por vírgulas; default n-executor)
# Opcional: SETUP_BOSS_EXECUTION_GRAPH_REPLAY_BOUNDARY_STOPS=n-review (paragens de subárvore; lista por vírgulas)

# Execution Graph Risk (Fase 4.12.8) — análise read-only de integridade / deadlock / replay (shadow)
SETUP_BOSS_EXECUTION_GRAPH_RISK=off
# off (default) | shadow → grava execution-graph-risk-report.json (sem bloquear pipeline)

# Execution Graph Release Readiness (Fase 4.12.9) — auditoria consolidada + execution-graph-release-readiness.json (shadow)
SETUP_BOSS_EXECUTION_GRAPH_RELEASE_READINESS=off
# off (default) | shadow → grava execution-graph-release-readiness.json no outputDir (best-effort; não altera pipeline)

# Opcional: SETUP_BOSS_EXECUTION_GRAPH_DEBUG=1 → shadow (4.12.x) log warn em falha de escrita

# Validation Runtime (Fase 4.2) — incremental, best-effort
SETUP_BOSS_VALIDATION_MODE=off
# off | report | active — report corre validators sem bloquear o executor (active reservado a enforcement futuro)
SETUP_BOSS_VALIDATION_POLICY_PROFILE=balanced
# minimal | balanced | strict — profundidade por estágios (structural/syntax/lightweight/semantic/project)
SETUP_BOSS_VALIDATION_TIMEOUT_MS=180000
SETUP_BOSS_VALIDATION_MAX_CONCURRENCY=2

# Validation-targeting + Semantic Dependency (Fase 4.8.4): candidatos shadow-only; não altera validation-targets.json nem validators
SETUP_BOSS_SEMANTIC_VALIDATION_PROPAGATION=off
# off (default) | shadow → grava validation-propagation-manifest.json (report-only)

# Risk Runtime (Fase 4.3) — motor de decisão sem bloquear executor
SETUP_BOSS_RISK_ENGINE=off
# off | telemetry | active — telemetry calcula e persiste risk-analysis.json; active acrescenta recomendações em metadata.json
# Limiares opcionais (score 0–100): SETUP_BOSS_RISK_TIER_MODERATE_MIN, SETUP_BOSS_RISK_TIER_HIGH_MIN, SETUP_BOSS_RISK_TIER_CRITICAL_MIN
# Pesos opcionais: SETUP_BOSS_RISK_WEIGHT_MUTATION_SCOPE, SETUP_BOSS_RISK_WEIGHT_VALIDATION_FAILURES, ...
# Integração Semantic Dependency → risk-runtime (Fase 4.8.5): bloco semantic_propagation em risk-analysis / manifest; não altera score
SETUP_BOSS_SEMANTIC_RISK_PROPAGATION=off
# off (default) | shadow → lê propagation-manifest.json + semantic-mutation-graph.json quando presentes

# Deterministic Review (Fase 4.4) — avaliação estruturada sem substituir correção/replay
SETUP_BOSS_REVIEW_ENGINE=off
# off → review legado (LLM) | structural → só motor determinístico | full → structural + heurísticas semânticas
# Integração Semantic Dependency → review-runtime (Fase 4.8.6): hints/métricas/manifestos report-only; não altera score
SETUP_BOSS_REVIEW_SEMANTIC_PROPAGATION=off
# off (default) | shadow → lê propagation-manifest.json + semantic-mutation-graph.json; grava review-semantic-propagation.json
# Gate opcional deterministic-review / risk_summary (Fase 4.11.5): não altera fingerprints do artefacto; default não bloqueante
# SETUP_BOSS_REVIEW_GATE_MODE=off
# off (default) | advisory (avisos; não muda exit do processo) | enforce (exit code 1 se overall_risk_level >= threshold)
# SETUP_BOSS_REVIEW_GATE_THRESHOLD=high
# low | medium | high | critical — valor inválido ou vazio é tratado como high. Comparação ordinal determinística (>=).
# Baseline / regression gate (Fase 4.11.7): opcional; artefacto separado review-baseline-summary.json; baseline ausente não bloqueia pipeline
# SETUP_BOSS_REVIEW_BASELINE_MODE=off
# off (default) | advisory | enforce — enforce → exit code 1 quando threshold violado (após gate 4.11.5)
# SETUP_BOSS_REVIEW_BASELINE_PATH=
# Caminho para deterministic-review.json de referência (absoluto ou relativo ao cwd)
# SETUP_BOSS_REVIEW_BASELINE_THRESHOLD=all
# all (default) | new_findings | risk_score_delta | gate_regression — lista separada por vírgula combina sinais (fixos); tokens inválidos ou lista vazia → perfil all
# Opcional: SETUP_BOSS_REVIEW_RECON_UNEXPECTED_MAX=0  (máx. mudanças inesperadas toleradas na reconciliação; default 0)

# Correction Runtime V2 — remediação runtime-guided (Fase 4.5)
SETUP_BOSS_CORRECTION_ENGINE=off
# off → sem intelligence layer | guided → artefacts + prompting enriquecido | active → supressão de retry por assinatura (sem rollback)
# Semantic Dependency → correction-runtime (Fase 4.8.7): hints/métricas/lineage refs report-only; não altera retry/decisão
SETUP_BOSS_CORRECTION_SEMANTIC_PROPAGATION=off
# off (default) | shadow → lê propagation-manifest.json + semantic-mutation-graph.json; grava correction-semantic-propagation.json
SETUP_BOSS_CORRECTION_SUPPRESS_STREAK=3
SETUP_BOSS_CORRECTION_PRIMING_TARGETS_CAP=20

# Transaction Runtime (Fase 4.6) — modelo transaccional replay-safe (sem rollback automático)
SETUP_BOSS_TRANSACTION_RUNTIME=off
# off → sem escritas extras | shadow → transaction-runtime.json, execution-snapshot(s), manifests, telemetry | active → mesmo + hints de recovery/rollback mais ricos nos finais

# Hybrid Executor — AST read-only shadow (Fase 4.9.1); não altera PATCH nem bloqueia o executor
HYBRID_EXECUTOR_ENABLED=false
STRUCTURAL_AST_READONLY_ENABLED=false
# Lista separada por vírgula: javascript | typescript (default implícito quando vazio = ambos)
STRUCTURAL_LANGUAGES_ENABLED=javascript,typescript

# Structural planning shadow (Fase 4.9.2): candidatos MVP + selectors (read-only; requer HYBRID + STRUCTURAL_AST_READONLY)
STRUCTURAL_PLANNING_ENABLED=false

# Shadow transforms (Fase 4.9.3): plano replace_node em memória vs patch textual — artefactos só em outputDir; requer PLANNING ligado + mesmo gate hybrid/AST-readonly
STRUCTURAL_SHADOW_TRANSFORMS_ENABLED=false

# Execução híbrida (Fase 4.9.4 / estabilização 4.9.4.1): structural-first com verificação contra o patch textual e fallback automático para o motor textual (sem bloquear o executor).
# Requisitos simultâneos: HYBRID_EXECUTOR_ENABLED + STRUCTURAL_AST_READONLY_ENABLED + STRUCTURAL_PLANNING_ENABLED + HYBRID_EXECUTION_ENABLED = true/on.
# Comportamento: tenta replace_node no span AST MVP; se o gate falhar, confidence < limiar, ou o resultado estrutural divergir do texto após normalizar EOL, aplica o mesmo patch via executor textual (previsível e seguro).
# Limitações MVP: só declarações MVP (ImportDeclaration, VariableDeclaration, FunctionDeclaration); sem transacções multi-ficheiro globais, sem replay estrutural, sem prettier/recast global.
# Artefactos (quando ligado): hybrid-execution-results.json, structural-fallback-report.json — métricas por patch, histogramas de fallback, sequencing por ficheiro.
HYBRID_EXECUTION_ENABLED=false
# Threshold 0–1 do score estrutural 0–100 (ex.: 0.90 ⇒ mínimo 90). Também aceita 90 (percentagem). Igual ao limiar inclusive passa (score >= mínimo).
STRUCTURAL_EXECUTION_MIN_CONFIDENCE=0.90

# Apply estrutural controlado (Fase 4.9.5): exige o mesmo gate que HYBRID_EXECUTION + HYBRID_EXECUTOR + STRUCTURAL_AST_READONLY + STRUCTURAL_PLANNING.
# Quando true: após o gate 4.9.4, o resultado estrutural só é aceite após reparse AST, validação mínima e verificação de drift fora do span MVP; falha → fallback textual e registo em structural-rollback-report.json.
# Artefactos adicionais: structural-apply-results.json, structural-post-validate.json, structural-rollback-report.json
# Hardening 4.9.5.1: sequencing (apply_ordering, apply_sequence), rollback_lineage, fallback_transitions, corruption_metrics nos JSON acima.
STRUCTURAL_APPLY_ENABLED=false

# Fundação replay estrutural (Fase 4.9.6.1): fingerprints, lineage, stale/idempotency diagnostics — relatórios apenas; default OFF.
STRUCTURAL_REPLAY_FOUNDATION_ENABLED=false
STRUCTURAL_IDEMPOTENCY_ENABLED=false
# Simulação de replay estrutural shadow (Fase 4.9.7): só relatórios; sem apply real nem mutação.
STRUCTURAL_REPLAY_SHADOW_ENABLED=false
# Consolidação observabilidade runtime híbrido (Fase 4.9.7.1): hybrid-runtime-summary.json + validação de artefactos presentes.
HYBRID_RUNTIME_OBSERVABILITY_ENABLED=false

# Governança estrutural incremental (Fase 4.9.6): relatórios + escalação MVP para operações de risco — não altera o executor textual; default OFF.
STRUCTURAL_GOVERNANCE_ENABLED=false
# warning (default) | block — `block` eleva o risco agregado quando há baixa confiança estrutural reportada.
STRUCTURAL_GOVERNANCE_LOW_CONFIDENCE_MODE=warning